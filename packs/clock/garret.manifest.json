{
  "apiVersion": 2,
  "id": "garret.clock",
  "publisher": "garret",
  "name": "Clock & Timers",
  "version": "1.1.0",
  "description": "Clock, world clock, timer, and stopwatch.",
  "widgets": [
    {
      "id": "clock",
      "name": "Clock",
      "ui": "dist/clock",
      "capabilities": [],
      "defaultSize": { "w": 3, "h": 3 },
      "settings": {
        "schema": [
          { "key": "format", "label": "Time format", "type": "select", "options": ["12-hour", "24-hour"], "default": "12-hour" },
          { "key": "showSeconds", "label": "Show seconds", "type": "boolean", "default": true }
        ]
      }
    },
    {
      "id": "world-clock",
      "name": "World Clock",
      "ui": "dist/world",
      "capabilities": [],
      "defaultSize": { "w": 3, "h": 4 }
    },
    {
      "id": "timer",
      "name": "Timer",
      "ui": "dist/timer",
      "capabilities": [],
      "defaultSize": { "w": 3, "h": 3 }
    },
    {
      "id": "stopwatch",
      "name": "Stopwatch",
      "ui": "dist/stopwatch",
      "capabilities": [],
      "defaultSize": { "w": 3, "h": 3 }
    }
  ]
}
