{
  "apiVersion": 2,
  "id": "garret.web-view",
  "publisher": "garret",
  "name": "Web View",
  "version": "1.1.0",
  "description": "Load any webpage from a URL.",
  "widgets": [
    {
      "id": "web",
      "name": "Web View",
      "description": "Pin any webpage to your board — a dashboard, docs, or a live page.",
      "ui": "dist/web",
      "preview": "previews/web.svg",
      "capabilities": ["embed"],
      "defaultSize": { "w": 6, "h": 5 },
      "settings": {
        "schema": [
          { "key": "url", "label": "Page URL", "type": "string", "default": "https://example.com", "placeholder": "https://…" }
        ]
      }
    }
  ]
}
