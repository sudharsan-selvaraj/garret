{
  "name": "garret",
  "version": "0.0.1",
  "description": "Garret — a macOS desktop layer for developer focus: ambient widgets above the wallpaper, a summon-over-everything HUD, and keyboard-driven action palettes (PRs, Jira, Git, Calendar, clipboard, dev tools).",
  "main": "out/main/index.js",
  "author": "Sudharsan Selvaraj",
  "license": "MIT",
  "workspaces": ["packages/*"],
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit",
    "build:packages": "npm run build -w garret-core && npm run build -w garret-widget-sdk",
    "setup:electron": "node node_modules/electron/install.js",
    "build:native": "cd native && node-gyp rebuild --target=31.7.7 --arch=arm64 --dist-url=https://electronjs.org/headers --devdir=../.electron-gyp",
    "build:icon": "bash scripts/make-icon.sh",
    "pack:dir": "npm run build:native && npm run build && electron-builder --dir",
    "pack:mac": "npm run build:native && npm run build && electron-builder --mac --publish never"
  },
  "dependencies": {
    "garret-core": "*",
    "garret-widget-sdk": "*",
    "electron-store": "^8.2.0",
    "lucide-react": "^0.460.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-grid-layout": "^1.5.3",
    "react-rnd": "^10.5.3",
    "undici": "^6.21.1",
    "zod": "^3.25.76",
    "zustand": "^4.5.7"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/react-grid-layout": "^1.3.6",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "node-addon-api": "^8.8.0",
    "node-gyp": "^10.3.1",
    "tsup": "^8.3.5",
    "typescript": "^5.5.0",
    "vite": "^5.3.0"
  }
}
