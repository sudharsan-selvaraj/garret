{
  "name": "garret-core",
  "version": "0.0.2",
  "description": "Pure shared layer for Garret widgets — types, field descriptors, validators, canonical poll keys. No React, no transport; shared verbatim by the host and by third-party widgets.",
  "license": "MIT",
  "author": "Sudharsan Selvaraj",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sudharsan-selvaraj/garret.git",
    "directory": "packages/core"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": { "types": "./dist/index.d.ts", "default": "./dist/index.js" },
      "require": { "types": "./dist/index.d.cts", "default": "./dist/index.cjs" }
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean --treeshake"
  },
  "dependencies": {
    "zod": "^3.25.76"
  }
}
