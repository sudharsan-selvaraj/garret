{
  "name": "garret-widget-sdk",
  "version": "0.0.2",
  "description": "Build widgets for Garret. createSDK(React, client) binds the hook logic to a realm's React + capability client; re-exports garret-core. The one package widget authors install.",
  "license": "MIT",
  "author": "Sudharsan Selvaraj",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sudharsan-selvaraj/garret.git",
    "directory": "packages/widget-sdk"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": { "types": "./dist/index.d.ts", "default": "./dist/index.js" },
      "require": { "types": "./dist/index.d.cts", "default": "./dist/index.cjs" }
    },
    "./testing": {
      "import": { "types": "./dist/testing.d.ts", "default": "./dist/testing.js" },
      "require": { "types": "./dist/testing.d.cts", "default": "./dist/testing.cjs" }
    },
    "./sandbox": {
      "import": { "types": "./dist/sandbox.d.ts", "default": "./dist/sandbox.js" },
      "require": { "types": "./dist/sandbox.d.cts", "default": "./dist/sandbox.cjs" }
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts src/testing.ts src/sandbox.ts --format esm,cjs --dts --clean --treeshake"
  },
  "dependencies": {
    "garret-core": "^0.0.2"
  },
  "peerDependencies": {
    "lucide-react": ">=0.263.0",
    "react": ">=18",
    "react-dom": ">=18"
  }
}
